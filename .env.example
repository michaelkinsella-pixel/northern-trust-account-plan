# Visitor gate (required in production)
SITE_PASSWORD=

# Admin dashboard at /admin → /api/admin-ui (separate from visitor password)
ADMIN_PASSWORD=

# TCP Redis (Redis Cloud, etc.) — redis:// or rediss://
# REDIS_URL is preferred (the Vercel integration injects it with the correct scheme).
# REDIS_CONNECTION_STRING is only a manual override when you need to force a value.
REDIS_URL=
REDIS_CONNECTION_STRING=

# If you do not have a single REDIS_URL, set host + password (and optional port / user):
# REDIS_HOST=redis-xxxxx.cloud.redislabs.com
# REDIS_PORT=15254
# REDIS_PASSWORD=your-database-password
# REDIS_USERNAME=default
# REDIS_TLS=1   (default: TLS on → rediss://)

# Upstash via Vercel integration (HTTP — no TCP URL needed). Omit if using REDIS_URL above.
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# Optional: skip visitor password in middleware (never enable in production)
# DISABLE_SITE_AUTH=1
